# ── Copy this file to .env and fill in your real keys ────────────────────────
# NEVER commit .env to git

# OpenRouter (LLM for all agents)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap (Geocoding + Weather forecast)
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Amadeus (Flights + Hotels) — free sandbox at developers.amadeus.com
AMADEUS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMADEUS_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RapidAPI (Indian Railways) — free tier at rapidapi.com
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Foursquare (Places) — free tier at foursquare.com/developer
FOURSQUARE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Logging level (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO
